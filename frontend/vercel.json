{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://excel-addin-currency-converter-3fci.vercel.app/api/$1"
    },
    {
      "src": "/",
      "dest": "/taskpane.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}